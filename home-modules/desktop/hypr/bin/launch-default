#!/usr/bin/env bash

workspace=${1:-$(hyprctl monitors -j | jq '.[] | select(.focused == true) | .activeWorkspace.id')}
case $workspace in
1)
  $BROWSER
  ;;
2)
  cmd="$TERMINAL -e tv sesh"
  $SHELL -c "$cmd"
  ;;
3)
  discord
  ;;
4)
  $TERMINAL -e yazi
  ;;
5)
  steam
  ;;
6)
  gimp
  ;;
7)
  $TERMINAL
  ;;
esac
