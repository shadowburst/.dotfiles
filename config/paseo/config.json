{
  "version": 1,
  "daemon": {
    "listen": "127.0.0.1:6767",
    "mcp": {
      "injectIntoAgents": true
    },
    "autoArchiveAfterMerge": true,
    "appendSystemPrompt": "",
    "cors": {
      "allowedOrigins": ["https://app.paseo.sh"]
    },
    "relay": {
      "enabled": true
    }
  },
  "app": {
    "baseUrl": "https://app.paseo.sh"
  },
  "agents": {
    "metadataGeneration": {
      "providers": [
        {
          "provider": "codex",
          "model": "gpt-5.4-mini",
          "thinkingOptionId": "low"
        }
      ]
    }
  }
}
