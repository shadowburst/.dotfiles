#!/usr/bin/env bash

# ============================================
# Ralphy - Autonomous AI Coding Loop
# Epic-driven flow over GitHub Issues + Matt Pocock's engineering skills.
#
# Picks the oldest open epic (parent issue), walks its sub-issues in dependency
# order, dispatches each one to the configured AI engine, and opens ONE PR per
# epic when its sub-issues are done. Then moves on to the next epic.
# ============================================

set -euo pipefail

# ============================================
# CONFIGURATION & DEFAULTS
# ============================================

VERSION="5.0.0"

RALPHY_DIR=".ralphy"
PROGRESS_FILE="$RALPHY_DIR/progress.txt"
CONFIG_FILE="$RALPHY_DIR/config.yaml"
INIT_MODE=false
SHOW_CONFIG=false
ADD_RULE=""

# Runtime options
AI_ENGINE="claude"
MODEL_OVERRIDE="sonnet"
DRY_RUN=false
MAX_ITERATIONS=100 # 0 = unlimited; counts sub-issue iterations
MAX_RETRIES=3
RETRY_DELAY=5
VERBOSE=false

# GitHub / epic options
REPO=""           # owner/repo; defaults to `gh repo view` of cwd
BASE="main"       # base branch the epic PR targets
EPIC_FILTER=""    # if set, only this epic number is processed

# Browser automation (agent-browser)
BROWSER_ENABLED="auto" # auto, true, false

# Constants
READY_LABEL="ready-for-agent"
IN_PR_LABEL="ralphy:in-pr"
SETUP_DOC="docs/agents/issue-tracker.md"

# Colors (detect if terminal supports colors)
if [[ -t 1 ]] && command -v tput &>/dev/null && [[ $(tput colors 2>/dev/null || echo 0) -ge 8 ]]; then
  RED=$(tput setaf 1)
  GREEN=$(tput setaf 2)
  YELLOW=$(tput setaf 3)
  BLUE=$(tput setaf 4)
  MAGENTA=$(tput setaf 5)
  CYAN=$(tput setaf 6)
  BOLD=$(tput bold)
  DIM=$(tput dim)
  RESET=$(tput sgr0)
else
  RED="" GREEN="" YELLOW="" BLUE="" MAGENTA="" CYAN="" BOLD="" DIM="" RESET=""
fi

# Global state
ai_pid=""
monitor_pid=""
tmpfile=""
CODEX_LAST_MESSAGE_FILE=""
current_step="Thinking"
total_input_tokens=0
total_output_tokens=0
total_actual_cost="0"
total_duration_ms=0
iteration=0
retry_count=0

# Per-iteration dispatch state. Bash picks the next sub-issue deterministically;
# the AI is told to execute it and emits an outcome tag, but the runner uses
# these values for the gh actions.
RALPHY_DISPATCHED_ISSUE=""
RALPHY_DISPATCHED_TITLE=""
RALPHY_DISPATCHED_JSON=""

# Disclaimer prefixed to every comment ralphy posts on a GitHub issue.
RALPHY_AI_COMMENT_DISCLAIMER="> *This comment was posted automatically by AI.*"

# Caches populated per epic-loop pass.
declare -A EPIC_PARENT_CREATED_AT=()  # epic# → ISO timestamp
declare -A EPIC_PARENT_STATE=()       # epic# → OPEN | CLOSED | UNKNOWN
declare -A EPIC_PARENT_TITLE=()       # epic# → title
declare -A SUBISSUE_BLOCKERS=()       # sub# → space-separated blocker numbers
declare -A SUBISSUE_BY_NUMBER=()      # sub# → JSON record
declare -a EPIC_SUBS_ORDERED=()       # ordered sub-issues for the active epic
declare -A ISSUE_STATE_CACHE=()       # issue# → state (cached gh issue view)

# ============================================
# UTILITY FUNCTIONS
# ============================================

log_info() {
  echo "${BLUE}[INFO]${RESET} $*"
}

log_success() {
  echo "${GREEN}[OK]${RESET} $*"
}

log_warn() {
  echo "${YELLOW}[WARN]${RESET} $*"
}

log_error() {
  echo "${RED}[ERROR]${RESET} $*" >&2
}

log_debug() {
  if [[ "$VERBOSE" == true ]]; then
    echo "${DIM}[DEBUG] $*${RESET}"
  fi
}

slugify() {
  echo "$1" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g' | sed -E 's/^-|-$//g' | cut -c1-50
}

is_browser_available() {
  if [[ "$BROWSER_ENABLED" == "false" ]]; then
    return 1
  fi
  if [[ "$BROWSER_ENABLED" == "true" ]]; then
    if ! command -v agent-browser &>/dev/null; then
      log_warn "--browser flag used but agent-browser CLI not found"
      log_warn "Install from: https://agent-browser.dev"
      return 1
    fi
    return 0
  fi
  command -v agent-browser &>/dev/null
}

get_browser_instructions() {
  if ! is_browser_available; then
    return
  fi

  cat <<'BROWSER_EOF'
## Browser Automation (agent-browser)
You have access to browser automation via the `agent-browser` CLI.

**Key Commands:**
- `agent-browser open <url>` - Open a URL in the browser
- `agent-browser snapshot` - Get accessibility tree with element refs (@e1, @e2, etc.)
- `agent-browser click @e1` - Click an element by reference
- `agent-browser type @e1 "text"` - Type text into an input field
- `agent-browser screenshot <file.png>` - Capture screenshot
- `agent-browser content` - Get page text content
- `agent-browser close` - Close browser session

**Workflow:**
1. Use `open` to navigate to a URL
2. Use `snapshot` to see available elements (returns refs like @e1, @e2)
3. Use `click`/`type` with element refs to interact
4. Use `screenshot` for visual verification

**Use browser automation for:**
- Testing web UI after implementing features
- Verifying deployments
- Filling forms or checking workflows
- Visual regression testing

BROWSER_EOF
}

# ============================================
# .ralphy/ CONFIG (rules + project context that feed into the prompt)
# ============================================

init_ralphy_config() {
  if [[ -d "$RALPHY_DIR" ]]; then
    log_warn "$RALPHY_DIR already exists"
    REPLY='N'
    read -p "Overwrite config? [y/N] " -n 1 -r -t 30 2>/dev/null || true
    echo
    [[ ! $REPLY =~ ^[Yy]$ ]] && exit 0
  fi

  mkdir -p "$RALPHY_DIR"

  local project_name=""
  local lang=""
  local framework=""
  local test_cmd=""
  local lint_cmd=""
  local build_cmd=""

  project_name=$(basename "$PWD")

  if [[ -f "package.json" ]]; then
    local pkg_name
    pkg_name=$(jq -r '.name // ""' package.json 2>/dev/null)
    [[ -n "$pkg_name" ]] && project_name="$pkg_name"

    if [[ -f "tsconfig.json" ]]; then
      lang="TypeScript"
    else
      lang="JavaScript"
    fi

    local deps frameworks=()
    deps=$(jq -r '(.dependencies // {}) + (.devDependencies // {}) | keys[]' package.json 2>/dev/null || true)

    echo "$deps" | grep -qx "next" && frameworks+=("Next.js")
    echo "$deps" | grep -qx "nuxt" && frameworks+=("Nuxt")
    echo "$deps" | grep -qx "@remix-run/react" && frameworks+=("Remix")
    echo "$deps" | grep -qx "svelte" && frameworks+=("Svelte")
    echo "$deps" | grep -qE "@nestjs/" && frameworks+=("NestJS")
    echo "$deps" | grep -qx "hono" && frameworks+=("Hono")
    echo "$deps" | grep -qx "fastify" && frameworks+=("Fastify")
    echo "$deps" | grep -qx "express" && frameworks+=("Express")
    if [[ ${#frameworks[@]} -eq 0 ]]; then
      echo "$deps" | grep -qx "react" && frameworks+=("React")
      echo "$deps" | grep -qx "vue" && frameworks+=("Vue")
    fi

    framework=$(
      IFS=', '
      echo "${frameworks[*]}"
    )

    local scripts
    scripts=$(jq -r '.scripts // {}' package.json 2>/dev/null)

    if echo "$scripts" | jq -e '.test' >/dev/null 2>&1; then
      test_cmd="npm test"
      [[ -f "bun.lockb" ]] && test_cmd="bun test"
    fi
    if echo "$scripts" | jq -e '.lint' >/dev/null 2>&1; then
      lint_cmd="npm run lint"
    fi
    if echo "$scripts" | jq -e '.build' >/dev/null 2>&1; then
      build_cmd="npm run build"
    fi

  elif [[ -f "pyproject.toml" ]] || [[ -f "requirements.txt" ]] || [[ -f "setup.py" ]]; then
    lang="Python"
    local py_frameworks=()
    local py_deps=""
    [[ -f "pyproject.toml" ]] && py_deps=$(cat pyproject.toml 2>/dev/null)
    [[ -f "requirements.txt" ]] && py_deps+=$(cat requirements.txt 2>/dev/null)
    echo "$py_deps" | grep -qi "fastapi" && py_frameworks+=("FastAPI")
    echo "$py_deps" | grep -qi "django" && py_frameworks+=("Django")
    echo "$py_deps" | grep -qi "flask" && py_frameworks+=("Flask")
    framework=$(
      IFS=', '
      echo "${py_frameworks[*]}"
    )
    test_cmd="pytest"
    lint_cmd="ruff check ."

  elif [[ -f "go.mod" ]]; then
    lang="Go"
    test_cmd="go test ./..."
    lint_cmd="golangci-lint run"

  elif [[ -f "Cargo.toml" ]]; then
    lang="Rust"
    test_cmd="cargo test"
    lint_cmd="cargo clippy"
    build_cmd="cargo build"
  fi

  echo ""
  echo "${BOLD}Detected:${RESET}"
  echo "  Project:   ${CYAN}$project_name${RESET}"
  [[ -n "$lang" ]] && echo "  Language:  ${CYAN}$lang${RESET}"
  [[ -n "$framework" ]] && echo "  Framework: ${CYAN}$framework${RESET}"
  [[ -n "$test_cmd" ]] && echo "  Test:      ${CYAN}$test_cmd${RESET}"
  [[ -n "$lint_cmd" ]] && echo "  Lint:      ${CYAN}$lint_cmd${RESET}"
  [[ -n "$build_cmd" ]] && echo "  Build:     ${CYAN}$build_cmd${RESET}"
  echo ""

  yaml_escape() { printf '%s' "$1" | sed 's/"/\\"/g'; }

  cat >"$CONFIG_FILE" <<EOF
# Ralphy Configuration

project:
  name: "$(yaml_escape "$project_name")"
  language: "$(yaml_escape "${lang:-Unknown}")"
  framework: "$(yaml_escape "${framework:-}")"
  description: ""

commands:
  test: "$(yaml_escape "${test_cmd:-}")"
  lint: "$(yaml_escape "${lint_cmd:-}")"
  build: "$(yaml_escape "${build_cmd:-}")"

# Rules - instructions injected into every prompt
rules: []

# Boundaries - files/folders the AI must not modify
boundaries:
  never_touch: []

capabilities:
  browser: "auto"
EOF

  echo "# Ralphy Progress Log" >"$PROGRESS_FILE"
  echo "" >>"$PROGRESS_FILE"

  log_success "Created $RALPHY_DIR/"
  echo ""
  echo "  ${CYAN}$CONFIG_FILE${RESET}   - Your rules and preferences"
  echo "  ${CYAN}$PROGRESS_FILE${RESET} - Progress log"
  echo ""
  echo "${BOLD}Next steps:${RESET}"
  echo "  1. Add rules:  ${CYAN}ralphy --add-rule \"your rule here\"${RESET}"
  echo "  2. Or edit:    ${CYAN}$CONFIG_FILE${RESET}"
}

load_ralphy_rules() {
  [[ ! -f "$CONFIG_FILE" ]] && return
  if command -v yq &>/dev/null; then
    yq -r '.rules // [] | .[]' "$CONFIG_FILE" 2>/dev/null || true
  fi
}

load_ralphy_boundaries() {
  local boundary_type="$1"
  [[ ! -f "$CONFIG_FILE" ]] && return
  if command -v yq &>/dev/null; then
    yq -r ".boundaries.$boundary_type // [] | .[]" "$CONFIG_FILE" 2>/dev/null || true
  fi
}

load_browser_setting() {
  [[ ! -f "$CONFIG_FILE" ]] && echo "auto" && return
  if command -v yq &>/dev/null; then
    yq -r '.capabilities.browser // "auto"' "$CONFIG_FILE" 2>/dev/null || echo "auto"
  else
    echo "auto"
  fi
}

show_ralphy_config() {
  if [[ ! -f "$CONFIG_FILE" ]]; then
    log_warn "No config found. Run 'ralphy --init' first."
    exit 1
  fi

  echo ""
  echo "${BOLD}Ralphy Configuration${RESET} ($CONFIG_FILE)"
  echo ""

  if command -v yq &>/dev/null; then
    local name lang framework desc
    name=$(yq -r '.project.name // "Unknown"' "$CONFIG_FILE" 2>/dev/null)
    lang=$(yq -r '.project.language // "Unknown"' "$CONFIG_FILE" 2>/dev/null)
    framework=$(yq -r '.project.framework // ""' "$CONFIG_FILE" 2>/dev/null)
    desc=$(yq -r '.project.description // ""' "$CONFIG_FILE" 2>/dev/null)

    echo "${BOLD}Project:${RESET}"
    echo "  Name:      $name"
    echo "  Language:  $lang"
    [[ -n "$framework" ]] && echo "  Framework: $framework"
    [[ -n "$desc" ]] && echo "  About:     $desc"
    echo ""

    local test_cmd lint_cmd build_cmd
    test_cmd=$(yq -r '.commands.test // ""' "$CONFIG_FILE" 2>/dev/null)
    lint_cmd=$(yq -r '.commands.lint // ""' "$CONFIG_FILE" 2>/dev/null)
    build_cmd=$(yq -r '.commands.build // ""' "$CONFIG_FILE" 2>/dev/null)

    echo "${BOLD}Commands:${RESET}"
    [[ -n "$test_cmd" ]] && echo "  Test:  $test_cmd" || echo "  Test:  ${DIM}(not set)${RESET}"
    [[ -n "$lint_cmd" ]] && echo "  Lint:  $lint_cmd" || echo "  Lint:  ${DIM}(not set)${RESET}"
    [[ -n "$build_cmd" ]] && echo "  Build: $build_cmd" || echo "  Build: ${DIM}(not set)${RESET}"
    echo ""

    echo "${BOLD}Rules:${RESET}"
    local rules
    rules=$(yq -r '.rules // [] | .[]' "$CONFIG_FILE" 2>/dev/null)
    if [[ -n "$rules" ]]; then
      echo "$rules" | while read -r rule; do
        echo "  • $rule"
      done
    else
      echo "  ${DIM}(none - add with: ralphy --add-rule \"...\")${RESET}"
    fi
    echo ""

    local never_touch
    never_touch=$(yq -r '.boundaries.never_touch // [] | .[]' "$CONFIG_FILE" 2>/dev/null)
    if [[ -n "$never_touch" ]]; then
      echo "${BOLD}Never Touch:${RESET}"
      echo "$never_touch" | while read -r path; do
        echo "  • $path"
      done
      echo ""
    fi

    local browser_setting
    browser_setting=$(yq -r '.capabilities.browser // "auto"' "$CONFIG_FILE" 2>/dev/null)
    echo "${BOLD}Capabilities:${RESET}"
    local browser_status="$browser_setting"
    if [[ "$browser_setting" == "auto" ]]; then
      if command -v agent-browser &>/dev/null; then
        browser_status="auto ${GREEN}(available)${RESET}"
      else
        browser_status="auto ${DIM}(not installed)${RESET}"
      fi
    fi
    echo "  Browser: $browser_status"
    echo ""
  else
    cat "$CONFIG_FILE"
  fi
}

add_ralphy_rule() {
  local rule="$1"

  if [[ ! -f "$CONFIG_FILE" ]]; then
    log_error "No config found. Run 'ralphy --init' first."
    exit 1
  fi
  if ! command -v yq &>/dev/null; then
    log_error "yq is required to add rules. Install from https://github.com/mikefarah/yq"
    log_info "Or manually edit $CONFIG_FILE"
    exit 1
  fi

  RULE="$rule" yq -i '.rules += [env(RULE)]' "$CONFIG_FILE"
  log_success "Added rule: $rule"
}

load_project_context() {
  [[ ! -f "$CONFIG_FILE" ]] && return
  if command -v yq &>/dev/null; then
    local name lang framework desc
    name=$(yq -r '.project.name // ""' "$CONFIG_FILE" 2>/dev/null)
    lang=$(yq -r '.project.language // ""' "$CONFIG_FILE" 2>/dev/null)
    framework=$(yq -r '.project.framework // ""' "$CONFIG_FILE" 2>/dev/null)
    desc=$(yq -r '.project.description // ""' "$CONFIG_FILE" 2>/dev/null)

    local context=""
    [[ -n "$name" ]] && context+="Project: $name\n"
    [[ -n "$lang" ]] && context+="Language: $lang\n"
    [[ -n "$framework" ]] && context+="Framework: $framework\n"
    [[ -n "$desc" ]] && context+="Description: $desc\n"
    echo -e "$context"
  fi
}

# ============================================
# HELP & VERSION
# ============================================

show_help() {
  cat <<EOF
${BOLD}Ralphy${RESET} - Epic-driven AI loop over GitHub Issues (v${VERSION})

${BOLD}USAGE:${RESET}
  ralphy [options]

${BOLD}WORKFLOW:${RESET}
  1. Picks the oldest open epic (parent issue) that has eligible sub-issues.
  2. Walks its sub-issues in dependency order (parses '## Blocked by').
  3. Dispatches each sub-issue to the AI; commits land on the epic branch.
  4. Opens ONE pull request per epic; the PR body's 'Closes #...' lines
     close the parent and all sub-issues on merge.
  5. Moves to the next epic.

  Sub-issues are eligible if they carry the '${READY_LABEL}' label
  and all their blockers are closed. Once a sub-issue is committed to
  the epic branch, ralphy strips '${READY_LABEL}' and adds
  '${IN_PR_LABEL}' so it isn't re-picked.

${BOLD}OPTIONS:${RESET}
  --repo OWNER/NAME    GitHub repo (default: gh repo view of cwd)
  --base BRANCH        Base branch for the epic PR (default: main)
  --epic NUM           Limit run to a single epic (parent issue number)
  --engine ENGINE      claude (default), opencode, cursor, codex,
                       qwen, droid, copilot
  --model NAME         Override default model for the engine
  --sonnet             Shortcut: --engine claude --model sonnet
  --max-iterations N   Stop after N sub-issue iterations (0 = unlimited)
  --max-retries N      Max retries per sub-issue on failure (default: 3)
  --retry-delay N      Seconds between retries (default: 5)
  --dry-run            Show what would be done without invoking the AI
  --browser            Enable browser automation (requires agent-browser)
  --no-browser         Disable browser automation
  -v, --verbose        Show debug output
  -h, --help           Show this help
  --version            Show version number

${BOLD}CONFIG (.ralphy/):${RESET}
  --init               Initialize .ralphy/config.yaml + progress.txt
  --config             Show current configuration
  --add-rule "..."     Append a rule that gets injected into every prompt

${BOLD}REQUIREMENTS:${RESET}
  - 'gh' CLI authenticated against the target repo
  - 'jq' for JSON parsing
  - The repo must have run /setup-matt-pocock-skills (i.e.
    ${SETUP_DOC} must exist).
EOF
}

show_version() {
  echo "Ralphy v${VERSION}"
}

# ============================================
# ARGUMENT PARSING
# ============================================

parse_args() {
  while [[ $# -gt 0 ]]; do
    case $1 in
    --repo)
      REPO="${2:-}"
      shift 2
      ;;
    --base | --base-branch)
      BASE="${2:-main}"
      shift 2
      ;;
    --epic)
      EPIC_FILTER="${2:-}"
      shift 2
      ;;
    --engine)
      AI_ENGINE="${2:-claude}"
      shift 2
      ;;
    --opencode) AI_ENGINE="opencode"; shift ;;
    --claude)   AI_ENGINE="claude"; shift ;;
    --cursor | --agent) AI_ENGINE="cursor"; shift ;;
    --codex)    AI_ENGINE="codex"; shift ;;
    --qwen)     AI_ENGINE="qwen"; shift ;;
    --droid)    AI_ENGINE="droid"; shift ;;
    --copilot)  AI_ENGINE="copilot"; shift ;;
    --sonnet)
      AI_ENGINE="claude"
      MODEL_OVERRIDE="sonnet"
      shift
      ;;
    --model)
      MODEL_OVERRIDE="${2:-}"
      shift 2
      ;;
    --dry-run)        DRY_RUN=true; shift ;;
    --max-iterations) MAX_ITERATIONS="${2:-0}"; shift 2 ;;
    --max-retries)    MAX_RETRIES="${2:-3}"; shift 2 ;;
    --retry-delay)    RETRY_DELAY="${2:-5}"; shift 2 ;;
    -v | --verbose)   VERBOSE=true; shift ;;
    -h | --help)      show_help; exit 0 ;;
    --version)        show_version; exit 0 ;;
    --init)           INIT_MODE=true; shift ;;
    --config)         SHOW_CONFIG=true; shift ;;
    --add-rule)
      [[ -z "${2:-}" ]] && {
        log_error "--add-rule requires an argument"
        exit 1
      }
      ADD_RULE="$2"
      shift 2
      ;;
    --browser)    BROWSER_ENABLED="true"; shift ;;
    --no-browser) BROWSER_ENABLED="false"; shift ;;
    -*)
      log_error "Unknown option: $1"
      echo "Use --help for usage"
      exit 1
      ;;
    *)
      log_error "Unexpected positional argument: $1"
      echo "Use --help for usage"
      exit 1
      ;;
    esac
  done
}

# ============================================
# PRE-FLIGHT CHECKS
# ============================================

check_requirements() {
  # Setup gate: matt-pocock skills must have written this file.
  if [[ ! -f "$SETUP_DOC" ]]; then
    log_error "$SETUP_DOC not found in current directory."
    log_info "Run /setup-matt-pocock-skills first to scaffold the agent docs."
    exit 1
  fi

  # AI CLI
  case "$AI_ENGINE" in
  opencode)
    command -v opencode &>/dev/null || { log_error "OpenCode CLI not found."; exit 1; }
    ;;
  codex)
    command -v codex &>/dev/null || { log_error "Codex CLI not found."; exit 1; }
    ;;
  cursor)
    command -v agent &>/dev/null || { log_error "Cursor agent CLI not found."; exit 1; }
    ;;
  qwen)
    command -v qwen &>/dev/null || { log_error "Qwen-Code CLI not found."; exit 1; }
    ;;
  droid)
    command -v droid &>/dev/null || { log_error "Factory Droid CLI not found."; exit 1; }
    ;;
  copilot)
    command -v copilot &>/dev/null || { log_error "GitHub Copilot CLI not found."; exit 1; }
    ;;
  claude | *)
    command -v claude &>/dev/null || {
      log_error "Claude Code CLI not found."
      log_info "Install from: https://github.com/anthropics/claude-code"
      log_info "Or use another engine via --engine."
      exit 1
    }
    ;;
  esac

  # Root check (claude/cursor refuse --dangerously-skip-permissions as root)
  if [[ "${EUID:-$(id -u)}" -eq 0 ]]; then
    case "$AI_ENGINE" in
    claude | cursor)
      log_error "Running as root is not supported with $AI_ENGINE."
      log_info "Use a different engine, or run as a non-root user."
      exit 1
      ;;
    *)
      log_warn "Running as root user. Some AI engines may have limited functionality."
      ;;
    esac
  fi

  command -v jq &>/dev/null || { log_error "jq is required."; exit 1; }
  command -v gh &>/dev/null || { log_error "GitHub CLI (gh) is required."; exit 1; }
  command -v git &>/dev/null || { log_error "git is required."; exit 1; }

  if ! git rev-parse --git-dir >/dev/null 2>&1; then
    log_error "Not a git repository."
    exit 1
  fi

  # Resolve REPO from `gh repo view` if not specified.
  if [[ -z "$REPO" ]]; then
    REPO=$(gh repo view --json nameWithOwner --jq '.nameWithOwner' 2>/dev/null || echo "")
    if [[ -z "$REPO" ]]; then
      log_error "Could not determine GitHub repo. Pass --repo owner/name."
      exit 1
    fi
    log_debug "Using repo: $REPO"
  fi

  # Ensure .ralphy/ + progress.txt for prompt enrichment.
  mkdir -p "$RALPHY_DIR"
  if [[ ! -f "$PROGRESS_FILE" ]]; then
    echo "# Ralphy Progress Log" >"$PROGRESS_FILE"
    echo "" >>"$PROGRESS_FILE"
  fi

  # Ensure the IN_PR_LABEL exists on the repo (idempotent).
  gh label create "$IN_PR_LABEL" \
    --repo "$REPO" \
    --color ededed \
    --description "Sub-issue picked up by ralphy; closure deferred to the epic PR" \
    >/dev/null 2>&1 || true
}

# ============================================
# CLEANUP HANDLER
# ============================================

cleanup() {
  local exit_code=$?
  [[ -n "$monitor_pid" ]] && kill "$monitor_pid" 2>/dev/null || true
  [[ -n "$ai_pid" ]] && kill "$ai_pid" 2>/dev/null || true
  pkill -P $$ 2>/dev/null || true
  [[ -n "$tmpfile" ]] && rm -f "$tmpfile"
  [[ -n "$CODEX_LAST_MESSAGE_FILE" ]] && rm -f "$CODEX_LAST_MESSAGE_FILE"

  if [[ $exit_code -eq 130 ]]; then
    printf "\n"
    log_warn "Interrupted! Cleaned up."
  fi
}

# ============================================
# EPIC DISCOVERY
# ============================================

# Extract the parent issue number from a sub-issue body. Looks for the first
# "## Parent" heading and pulls a #N / owner/repo#N / GitHub URL out of it.
parse_parent_ref() {
  local body=$1
  local block
  block=$(printf '%s\n' "$body" | awk '
    BEGIN { inblock = 0 }
    /^##[[:space:]]+Parent[[:space:]]*$/ { inblock = 1; next }
    inblock && /^##[[:space:]]+/ { exit }
    inblock { print }
  ')

  [[ -z "$block" ]] && return

  local n
  n=$(printf '%s\n' "$block" | grep -oE 'https://github\.com/[^/]+/[^/]+/issues/[0-9]+' | head -1 | grep -oE '[0-9]+$' || true)
  [[ -n "$n" ]] && { echo "$n"; return; }

  n=$(printf '%s\n' "$block" | grep -oE '[A-Za-z0-9._-]+/[A-Za-z0-9._-]+#[0-9]+' | head -1 | grep -oE '[0-9]+$' || true)
  [[ -n "$n" ]] && { echo "$n"; return; }

  n=$(printf '%s\n' "$block" | grep -oE '#[0-9]+' | head -1 | tr -d '#' || true)
  [[ -n "$n" ]] && echo "$n"
}

# Extract blocker issue numbers from a sub-issue body's "## Blocked by" section.
parse_blocked_by() {
  local body=$1
  local block
  block=$(printf '%s\n' "$body" | awk '
    BEGIN { inblock = 0 }
    /^##[[:space:]]+Blocked[[:space:]]+[Bb]y[[:space:]]*$/ { inblock = 1; next }
    inblock && /^##[[:space:]]+/ { exit }
    inblock { print }
  ')

  [[ -z "$block" ]] && return

  printf '%s\n' "$block" \
    | grep -oE '#[0-9]+' \
    | tr -d '#' \
    | sort -u \
    | tr '\n' ' '
}

# Cached lookup of an issue's state (OPEN / CLOSED).
get_issue_state() {
  local n=$1
  if [[ -n "${ISSUE_STATE_CACHE[$n]:-}" ]]; then
    echo "${ISSUE_STATE_CACHE[$n]}"
    return
  fi
  local state
  state=$(gh issue view "$n" --repo "$REPO" --json state --jq '.state' 2>/dev/null || echo "UNKNOWN")
  [[ -z "$state" ]] && state="UNKNOWN"
  ISSUE_STATE_CACHE[$n]=$state
  echo "$state"
}

# Fetch + cache parent metadata (createdAt, state, title) for one epic.
fetch_parent_metadata() {
  local epic=$1
  [[ -n "${EPIC_PARENT_CREATED_AT[$epic]:-}" ]] && return 0

  local meta
  meta=$(gh issue view "$epic" --repo "$REPO" --json createdAt,state,title 2>/dev/null || echo "")
  if [[ -z "$meta" ]]; then
    EPIC_PARENT_CREATED_AT[$epic]="9999-12-31T00:00:00Z"
    EPIC_PARENT_STATE[$epic]="UNKNOWN"
    EPIC_PARENT_TITLE[$epic]="(unknown)"
    return 1
  fi

  EPIC_PARENT_CREATED_AT[$epic]=$(printf '%s' "$meta" | jq -r '.createdAt // ""')
  EPIC_PARENT_STATE[$epic]=$(printf '%s' "$meta" | jq -r '.state // "UNKNOWN"')
  EPIC_PARENT_TITLE[$epic]=$(printf '%s' "$meta" | jq -r '.title // ""')
}

# Populate EPIC_PARENT_*, SUBISSUE_BLOCKERS, SUBISSUE_BY_NUMBER from a single
# `gh issue list` over open `ready-for-agent` issues, grouping by parent#.
# Sets the global EPIC_LIST array (epic numbers, deduped).
declare -a EPIC_LIST=()
discover_epics() {
  EPIC_PARENT_CREATED_AT=()
  EPIC_PARENT_STATE=()
  EPIC_PARENT_TITLE=()
  SUBISSUE_BLOCKERS=()
  SUBISSUE_BY_NUMBER=()
  ISSUE_STATE_CACHE=()
  EPIC_LIST=()

  local raw
  raw=$(gh issue list \
    --repo "$REPO" \
    --state open \
    --label "$READY_LABEL" \
    --limit 500 \
    --json number,title,body,labels,createdAt,comments 2>/dev/null || echo "[]")

  local count
  count=$(printf '%s' "$raw" | jq 'length' 2>/dev/null || echo 0)
  [[ "$count" -eq 0 ]] && return 0

  declare -A seen_epic=()

  local i
  for ((i = 0; i < count; i++)); do
    local rec sub_num sub_body parent blockers
    rec=$(printf '%s' "$raw" | jq ".[$i]")
    sub_num=$(printf '%s' "$rec" | jq -r '.number')
    sub_body=$(printf '%s' "$rec" | jq -r '.body // ""')

    # Skip sub-issues already accumulated into a pending PR.
    if printf '%s' "$rec" | jq -e '[.labels[].name] | index("'"$IN_PR_LABEL"'")' >/dev/null 2>&1; then
      continue
    fi

    parent=$(parse_parent_ref "$sub_body" || true)
    if [[ -z "$parent" ]]; then
      # Orphan sub-issue → degenerate one-issue self-epic.
      parent=$sub_num
    fi

    # Honour --epic filter.
    if [[ -n "$EPIC_FILTER" && "$parent" != "$EPIC_FILTER" ]]; then
      continue
    fi

    blockers=$(parse_blocked_by "$sub_body" || true)
    SUBISSUE_BLOCKERS[$sub_num]=$blockers
    SUBISSUE_BY_NUMBER[$sub_num]=$rec

    if [[ -z "${seen_epic[$parent]:-}" ]]; then
      seen_epic[$parent]=1
      EPIC_LIST+=("$parent")
    fi
  done
}

# Pick the oldest epic by parent createdAt that has at least one sub-issue
# whose blockers are all closed. Sets RALPHY_EPIC and RALPHY_EPIC_TITLE.
RALPHY_EPIC=""
RALPHY_EPIC_TITLE=""
select_active_epic() {
  RALPHY_EPIC=""
  RALPHY_EPIC_TITLE=""

  [[ ${#EPIC_LIST[@]} -eq 0 ]] && return 1

  # Materialise (createdAt \t epic#) lines, sort, then walk.
  local sorted_epics=()
  local tmpsort
  tmpsort=$(mktemp)
  local e
  for e in "${EPIC_LIST[@]}"; do
    fetch_parent_metadata "$e" || true
    local created="${EPIC_PARENT_CREATED_AT[$e]:-9999-12-31T00:00:00Z}"
    printf '%s\t%s\n' "$created" "$e" >>"$tmpsort"
  done

  while IFS=$'\t' read -r _ e; do
    sorted_epics+=("$e")
  done < <(sort "$tmpsort")
  rm -f "$tmpsort"

  for e in "${sorted_epics[@]}"; do
    # Skip closed-parent epics (unless orphan self-epic).
    local pstate="${EPIC_PARENT_STATE[$e]:-UNKNOWN}"
    if [[ "$pstate" == "CLOSED" ]]; then
      log_debug "Skipping epic #$e: parent issue is closed"
      continue
    fi

    if epic_has_eligible_subissue "$e"; then
      RALPHY_EPIC=$e
      RALPHY_EPIC_TITLE="${EPIC_PARENT_TITLE[$e]:-#$e}"
      return 0
    else
      log_debug "Epic #$e has no eligible sub-issues; skipping"
    fi
  done

  return 1
}

# True if any sub-issue of the given epic has all blockers closed.
epic_has_eligible_subissue() {
  local epic=$1
  local sub
  for sub in "${!SUBISSUE_BY_NUMBER[@]}"; do
    local rec_parent
    rec_parent=$(parse_parent_ref "$(printf '%s' "${SUBISSUE_BY_NUMBER[$sub]}" | jq -r '.body // ""')" || true)
    [[ -z "$rec_parent" ]] && rec_parent=$sub
    [[ "$rec_parent" != "$epic" ]] && continue

    if subissue_blockers_clear "$sub"; then
      return 0
    fi
  done
  return 1
}

# True if every blocker of this sub-issue is CLOSED.
subissue_blockers_clear() {
  local sub=$1
  local blockers="${SUBISSUE_BLOCKERS[$sub]:-}"
  [[ -z "$blockers" ]] && return 0

  local b
  for b in $blockers; do
    local s
    s=$(get_issue_state "$b")
    [[ "$s" != "CLOSED" ]] && return 1
  done
  return 0
}

# Order sub-issues for the active epic: by createdAt ascending, eligible only.
order_epic_subissues() {
  local epic=$1
  EPIC_SUBS_ORDERED=()

  local tmpsort
  tmpsort=$(mktemp)

  local sub
  for sub in "${!SUBISSUE_BY_NUMBER[@]}"; do
    local rec="${SUBISSUE_BY_NUMBER[$sub]}"
    local rec_parent
    rec_parent=$(parse_parent_ref "$(printf '%s' "$rec" | jq -r '.body // ""')" || true)
    [[ -z "$rec_parent" ]] && rec_parent=$sub
    [[ "$rec_parent" != "$epic" ]] && continue

    local created
    created=$(printf '%s' "$rec" | jq -r '.createdAt // ""')
    printf '%s\t%s\n' "$created" "$sub" >>"$tmpsort"
  done

  while IFS=$'\t' read -r _ sub; do
    EPIC_SUBS_ORDERED+=("$sub")
  done < <(sort "$tmpsort")
  rm -f "$tmpsort"
}

# Return the next sub-issue whose blockers are all closed and who hasn't been
# processed in this run. Populates RALPHY_DISPATCHED_*.
declare -A SUBISSUE_PROCESSED=()
pick_next_subissue() {
  local sub
  for sub in "${EPIC_SUBS_ORDERED[@]}"; do
    [[ -n "${SUBISSUE_PROCESSED[$sub]:-}" ]] && continue
    subissue_blockers_clear "$sub" || continue

    local rec="${SUBISSUE_BY_NUMBER[$sub]}"
    RALPHY_DISPATCHED_ISSUE=$sub
    RALPHY_DISPATCHED_TITLE=$(printf '%s' "$rec" | jq -r '.title')
    RALPHY_DISPATCHED_JSON=$rec
    return 0
  done

  RALPHY_DISPATCHED_ISSUE=""
  RALPHY_DISPATCHED_TITLE=""
  RALPHY_DISPATCHED_JSON=""
  return 1
}

# ============================================
# EPIC BRANCH + PR HELPERS
# ============================================

epic_branch_name() {
  local epic=$1
  local title=$2
  local slug
  slug=$(slugify "$title")
  [[ -z "$slug" ]] && slug="epic"
  echo "ralphy/epic-${epic}-${slug}"
}

# Create or reuse the epic branch. If it exists locally, check it out and
# rebase onto $BASE. If it exists only on origin, fetch and check out a tracking
# branch. If new, branch from the up-to-date $BASE.
ensure_epic_branch() {
  local epic=$1
  local title=$2
  local branch
  branch=$(epic_branch_name "$epic" "$title")

  log_info "Preparing epic branch ${CYAN}$branch${RESET}"

  git fetch origin "$BASE" --quiet 2>/dev/null || true

  # Make sure base is current locally.
  if git show-ref --verify --quiet "refs/heads/$BASE"; then
    git checkout "$BASE" >/dev/null 2>&1 || true
    git pull --ff-only origin "$BASE" >/dev/null 2>&1 || true
  else
    git checkout -B "$BASE" "origin/$BASE" >/dev/null 2>&1 || true
  fi

  if git show-ref --verify --quiet "refs/heads/$branch"; then
    log_debug "Local branch exists; checking out and rebasing onto $BASE"
    git checkout "$branch" >/dev/null 2>&1 || {
      log_error "Failed to checkout existing branch $branch"
      return 1
    }
    if ! git rebase "$BASE" >/dev/null 2>&1; then
      log_warn "Rebase onto $BASE conflicted; aborting and continuing without rebase"
      git rebase --abort >/dev/null 2>&1 || true
    fi
  elif git ls-remote --exit-code --heads origin "$branch" >/dev/null 2>&1; then
    log_debug "Remote branch exists; tracking it locally"
    git fetch origin "$branch" --quiet 2>/dev/null || true
    git checkout -B "$branch" "origin/$branch" >/dev/null 2>&1 || {
      log_error "Failed to track remote branch $branch"
      return 1
    }
    if ! git rebase "$BASE" >/dev/null 2>&1; then
      log_warn "Rebase onto $BASE conflicted; aborting and continuing without rebase"
      git rebase --abort >/dev/null 2>&1 || true
    fi
  else
    log_debug "Creating new branch $branch from $BASE"
    git checkout -b "$branch" "$BASE" >/dev/null 2>&1 || {
      log_error "Failed to create branch $branch"
      return 1
    }
  fi

  echo "$branch"
}

# Strip ready-for-agent, add ralphy:in-pr (closure deferred to PR merge).
mark_subissue_in_pr() {
  local sub=$1
  log_debug "Marking #$sub as in-pr"
  gh issue edit "$sub" \
    --repo "$REPO" \
    --remove-label "$READY_LABEL" \
    --add-label "$IN_PR_LABEL" >/dev/null 2>&1 || \
    log_warn "Failed to flip labels on issue #$sub"
}

# Push the epic branch and open the PR. $5 is "true" for draft.
open_epic_pr() {
  local epic=$1
  local epic_title=$2
  local branch=$3
  local -n _completed_subs=$4
  local draft=$5

  log_info "Pushing $branch and opening pull request"

  git push -u origin "$branch" >/dev/null 2>&1 || {
    log_warn "Failed to push branch $branch"
    return 1
  }

  local body
  body="Closes #${epic}"$'\n'
  local s
  for s in "${_completed_subs[@]}"; do
    body+="Closes #${s}"$'\n'
  done
  body+=$'\n'"Automated by ralphy. Sub-issues processed in dependency order on the epic branch."

  local draft_flag=""
  [[ "$draft" == "true" ]] && draft_flag="--draft"

  local pr_url
  pr_url=$(gh pr create \
    --repo "$REPO" \
    --base "$BASE" \
    --head "$branch" \
    --title "Epic #${epic}: ${epic_title}" \
    --body "$body" \
    $draft_flag 2>/dev/null) || {
    log_warn "Failed to create PR (a PR may already exist for $branch)"
    return 1
  }

  log_success "Pull request opened: $pr_url"
  echo "$pr_url"
}

# ============================================
# AI ENGINE ABSTRACTION
# ============================================

run_ai_command() {
  local prompt=$1
  local output_file=$2

  case "$AI_ENGINE" in
  opencode)
    OPENCODE_PERMISSION='{"*":"allow"}' opencode run \
      ${MODEL_OVERRIDE:+--model "$MODEL_OVERRIDE"} \
      --format json \
      "$prompt" >"$output_file" 2>&1 &
    ;;
  cursor)
    agent --print --force \
      --output-format stream-json \
      "$prompt" >"$output_file" 2>&1 &
    ;;
  qwen)
    qwen --output-format stream-json \
      --approval-mode yolo \
      -p "$prompt" >"$output_file" 2>&1 &
    ;;
  droid)
    droid exec --output-format stream-json \
      --auto medium \
      "$prompt" >"$output_file" 2>&1 &
    ;;
  copilot)
    copilot -p "$prompt" \
      ${MODEL_OVERRIDE:+--model "$MODEL_OVERRIDE"} \
      >"$output_file" 2>&1 &
    ;;
  codex)
    CODEX_LAST_MESSAGE_FILE="${output_file}.last"
    rm -f "$CODEX_LAST_MESSAGE_FILE"
    codex exec --full-auto \
      --json \
      --output-last-message "$CODEX_LAST_MESSAGE_FILE" \
      "$prompt" >"$output_file" 2>&1 &
    ;;
  *)
    claude --dangerously-skip-permissions \
      ${MODEL_OVERRIDE:+--model "$MODEL_OVERRIDE"} \
      --verbose \
      --output-format stream-json \
      -p "$prompt" >"$output_file" 2>&1 &
    ;;
  esac

  ai_pid=$!
}

parse_ai_result() {
  local result=$1
  local response=""
  local input_tokens=0
  local output_tokens=0
  local actual_cost="0"

  case "$AI_ENGINE" in
  opencode)
    local step_finish
    step_finish=$(echo "$result" | grep '"type":"step_finish"' | tail -1 || echo "")

    if [[ -n "$step_finish" ]]; then
      input_tokens=$(echo "$step_finish" | jq -r '.part.tokens.input // 0' 2>/dev/null || echo "0")
      output_tokens=$(echo "$step_finish" | jq -r '.part.tokens.output // 0' 2>/dev/null || echo "0")
      actual_cost=$(echo "$step_finish" | jq -r '.part.cost // 0' 2>/dev/null || echo "0")
    fi

    response=$(echo "$result" | grep '"type":"text"' | jq -rs 'map(.part.text // "") | join("")' 2>/dev/null || echo "")
    [[ -z "$response" ]] && response="Task completed"
    ;;
  cursor)
    if [[ -z "$response" ]] || [[ "$response" == "Task completed" ]]; then
      local assistant_msg
      assistant_msg=$(echo "$result" | grep '"type":"assistant"' | tail -1)
      if [[ -n "$assistant_msg" ]]; then
        response=$(echo "$assistant_msg" | jq -r '.message.content[0].text // .message.content // "Task completed"' 2>/dev/null || echo "Task completed")
      fi
    fi
    input_tokens=0
    output_tokens=0
    ;;
  copilot)
    local filtered_output
    filtered_output=$(echo "$result" | grep -v "^\?" | grep -v "^❯" | grep -v "Thinking..." | grep -v "Working on it..." | sed '/^$/d')
    response=$(echo "$filtered_output" | head -20 | tail -10 || echo "Task completed")
    input_tokens=0
    output_tokens=0
    ;;
  qwen)
    local result_line
    result_line=$(echo "$result" | grep '"type":"result"' | tail -1)
    if [[ -n "$result_line" ]]; then
      response=$(echo "$result_line" | jq -r '.result // "No result text"' 2>/dev/null || echo "Could not parse result")
      input_tokens=$(echo "$result_line" | jq -r '.usage.input_tokens // 0' 2>/dev/null || echo "0")
      output_tokens=$(echo "$result_line" | jq -r '.usage.output_tokens // 0' 2>/dev/null || echo "0")
    fi
    [[ -z "$response" ]] && response="Task completed"
    ;;
  droid)
    local completion_line
    completion_line=$(echo "$result" | grep '"type":"completion"' | tail -1)
    if [[ -n "$completion_line" ]]; then
      response=$(echo "$completion_line" | jq -r '.finalText // "Task completed"' 2>/dev/null || echo "Task completed")
      local dur_ms
      dur_ms=$(echo "$completion_line" | jq -r '.durationMs // 0' 2>/dev/null || echo "0")
      if [[ "$dur_ms" =~ ^[0-9]+$ ]] && [[ "$dur_ms" -gt 0 ]]; then
        actual_cost="duration:$dur_ms"
      fi
    fi
    input_tokens=0
    output_tokens=0
    ;;
  codex)
    if [[ -n "$CODEX_LAST_MESSAGE_FILE" ]] && [[ -f "$CODEX_LAST_MESSAGE_FILE" ]]; then
      response=$(cat "$CODEX_LAST_MESSAGE_FILE" 2>/dev/null || echo "")
      response=$(printf '%s' "$response" | sed '1{/^Task completed successfully\.[[:space:]]*$/d;}')
    fi
    input_tokens=0
    output_tokens=0
    ;;
  *)
    local result_line
    result_line=$(echo "$result" | grep '"type":"result"' | tail -1)
    if [[ -n "$result_line" ]]; then
      response=$(echo "$result_line" | jq -r '.result // "No result text"' 2>/dev/null || echo "Could not parse result")
      input_tokens=$(echo "$result_line" | jq -r '.usage.input_tokens // 0' 2>/dev/null || echo "0")
      output_tokens=$(echo "$result_line" | jq -r '.usage.output_tokens // 0' 2>/dev/null || echo "0")
    fi
    ;;
  esac

  [[ "$input_tokens" =~ ^[0-9]+$ ]] || input_tokens=0
  [[ "$output_tokens" =~ ^[0-9]+$ ]] || output_tokens=0

  echo "$response"
  echo "---TOKENS---"
  echo "$input_tokens"
  echo "$output_tokens"
  echo "$actual_cost"
}

check_for_errors() {
  local result=$1

  if echo "$result" | grep -q '"type":"error"'; then
    local error_msg
    error_msg=$(echo "$result" | grep '"type":"error"' | head -1 | jq -r '.error.data.message // .error.message // .message // "Unknown error"' 2>/dev/null || echo "Unknown error")
    echo "$error_msg"
    return 1
  fi
  return 0
}

calculate_cost() {
  local input=$1
  local output=$2

  if command -v bc &>/dev/null; then
    echo "scale=4; ($input * 0.000003) + ($output * 0.000015)" | bc
  else
    echo "N/A"
  fi
}

# ============================================
# PROGRESS MONITOR
# ============================================

monitor_progress() {
  local file=$1
  local task=$2
  local start_time
  start_time=$(date +%s)
  local spinstr='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
  local spin_idx=0

  task="${task:0:40}"

  while true; do
    local elapsed=$(($(date +%s) - start_time))
    local mins=$((elapsed / 60))
    local secs=$((elapsed % 60))

    if [[ -f "$file" ]] && [[ -s "$file" ]]; then
      local content
      content=$(tail -c 5000 "$file" 2>/dev/null || true)

      if echo "$content" | grep -qE '"command":"git commit'; then
        current_step="Committing"
      elif echo "$content" | grep -qE '"command":"git add'; then
        current_step="Staging"
      elif echo "$content" | grep -qE '"name":"[WwEe](rite|dit)"'; then
        current_step="Implementing"
      elif echo "$content" | grep -qE '"name":"[RrGg](ead|lob|rep)"'; then
        current_step="Reading code"
      fi
    fi

    local spinner_char="${spinstr:$spin_idx:1}"
    local step_color=""

    case "$current_step" in
    "Thinking" | "Reading code") step_color="$CYAN" ;;
    "Implementing") step_color="$MAGENTA" ;;
    "Staging" | "Committing") step_color="$GREEN" ;;
    *) step_color="$BLUE" ;;
    esac

    tput cr 2>/dev/null || printf "\r"
    tput el 2>/dev/null || true
    printf "  %s ${step_color}%-16s${RESET} │ %s ${DIM}[%02d:%02d]${RESET}" "$spinner_char" "$current_step" "$task" "$mins" "$secs"

    spin_idx=$(((spin_idx + 1) % ${#spinstr}))
    sleep 0.12
  done
}

# ============================================
# NOTIFICATION
# ============================================

notify_done() {
  local message="${1:-Ralphy has completed its run!}"

  if command -v osascript &>/dev/null; then
    osascript -e "display notification \"$message\" with title \"Ralphy\"" 2>/dev/null || true
  fi
  if command -v notify-send &>/dev/null; then
    notify-send "Ralphy" "$message" 2>/dev/null || true
  fi
  if command -v paplay &>/dev/null; then
    paplay /usr/share/sounds/freedesktop/stereo/complete.oga 2>/dev/null &
  fi
  if command -v powershell.exe &>/dev/null; then
    powershell.exe -Command "[System.Media.SystemSounds]::Asterisk.Play()" 2>/dev/null || true
  fi
}

notify_error() {
  local message="${1:-Ralphy encountered an error}"
  if command -v osascript &>/dev/null; then
    osascript -e "display notification \"$message\" with title \"Ralphy - Error\"" 2>/dev/null || true
  fi
  if command -v notify-send &>/dev/null; then
    notify-send -u critical "Ralphy - Error" "$message" 2>/dev/null || true
  fi
}

# ============================================
# PROMPT BUILDER
# ============================================

build_subissue_prompt() {
  local issue_num="$RALPHY_DISPATCHED_ISSUE"
  local issue_json="$RALPHY_DISPATCHED_JSON"
  local epic_num="$RALPHY_EPIC"
  local epic_title="$RALPHY_EPIC_TITLE"

  local prompt=""

  # Per-repo .ralphy/ context (if present).
  if [[ -d "$RALPHY_DIR" ]]; then
    local context
    context=$(load_project_context)
    if [[ -n "$context" ]]; then
      prompt+="## Project Context
$context

"
    fi

    local rules
    rules=$(load_ralphy_rules)
    if [[ -n "$rules" ]]; then
      prompt+="## Rules (you MUST follow these)
$rules

"
    fi

    local never_touch
    never_touch=$(load_ralphy_boundaries "never_touch")
    if [[ -n "$never_touch" ]]; then
      prompt+="## Boundaries - Do NOT modify these files:
$never_touch

"
    fi
  fi

  local browser_instructions
  browser_instructions=$(get_browser_instructions)
  if [[ -n "$browser_instructions" ]]; then
    prompt+="$browser_instructions

"
  fi

  local commits
  commits=$(git log --all --grep='^RALPH:' -n 10 --format='%H %ai%n%s%n%b%n---' 2>/dev/null || true)
  [[ -z "$commits" ]] && commits="No prior RALPH commits."

  prompt+=$(cat <<RALPH_EOF

# CONTEXT

You are working inside ralphy's epic-driven loop. The runner has selected
sub-issue #${issue_num} from epic #${epic_num} ("${epic_title}"). The full
sub-issue record (body, labels, comments — note the comment thread typically
contains an "agent brief" written by the human triager) is below as JSON:

\`\`\`json
$issue_json
\`\`\`

Last 10 RALPH commits on this branch family:
\`\`\`
$commits
\`\`\`

# AGENT DOCS

This repo has been configured by /setup-matt-pocock-skills. Authoritative
guidance lives in:

- \`${SETUP_DOC}\` — how to interact with the issue tracker (gh CLI conventions).
- \`docs/agents/triage-labels.md\` — the project's triage label vocabulary.
- \`docs/agents/domain.md\` — domain doc layout. Read \`CONTEXT.md\` /
  \`CONTEXT-MAP.md\` for the project's domain glossary, and any relevant
  ADR under \`docs/adr/\` for architectural decisions in the area you are
  touching.

You may invoke other Matt Pocock engineering skills as needed:

- \`/tdd\` — when the agent brief asks for tests or behaviour-driven changes.
- \`/improve-codebase-architecture\` — for refactors or module re-shaping.
- \`/diagnose\` — when investigating a defect referenced by the issue.

# EXPLORATION

Read the agent brief comment carefully — it is the source of truth for what
to build. Then explore the repo and load the context (relevant code paths,
domain docs, adjacent ADRs) you need.

# EXECUTION

Implement the work for sub-issue #${issue_num}. Stay strictly inside the
scope described in the brief. The runner has already prepared the epic
branch; do not switch branches yourself.

# COMMIT

Make a single git commit on the current branch. The commit message MUST:

1. Start with \`RALPH:\` prefix.
2. Reference the sub-issue (e.g. \`#${issue_num}\`) and the epic (e.g. \`epic #${epic_num}\`).
3. Summarise the key decisions made.
4. List files changed.
5. Note any blockers or follow-ups.

Keep it concise.

# OUTCOME REPORTING

Do NOT call \`gh issue close\`, \`gh issue comment\`, or \`gh issue edit\`.
The runner accumulates sub-issues and closes them via the epic PR. Signal
the outcome of THIS sub-issue with one of the tags below as the final line
of your output:

- \`<issue-complete>${issue_num}</issue-complete>\` — sub-issue is fully done.
- \`<issue-incomplete number="${issue_num}">progress notes here, multi-line ok</issue-incomplete>\` — partial progress; the runner will post the notes as a comment AND demote the sub-issue from \`${READY_LABEL}\` to \`needs-info\` so a human can re-triage.
- \`<promise>COMPLETE</promise>\` — only if the sub-issue turns out to require no work (already done, duplicate, etc.).

# FINAL RULES

ONLY WORK ON THIS SINGLE SUB-ISSUE.
RALPH_EOF
)

  echo "$prompt"
}

# ============================================
# OUTCOME HANDLING
# ============================================

# Returns:
#   0 → complete (caller adds the sub-issue to completed list)
#   1 → incomplete (caller marks epic as partial)
#   2 → no-work / promise:complete
#   3 → no tag (caller treats as partial / break)
handle_subissue_outcome() {
  local result=$1
  local issue_num=$2

  if printf '%s' "$result" | grep -qE '<issue-complete>[0-9]+</issue-complete>'; then
    return 0
  fi

  local incomplete_notes
  incomplete_notes=$(printf '%s' "$result" | perl -0777 -ne 'print $1 if /<issue-incomplete\s+number="\d+">(.*?)<\/issue-incomplete>/s' 2>/dev/null || true)
  if [[ -n "$incomplete_notes" ]]; then
    log_info "AI signaled partial progress on issue #$issue_num — commenting + demoting"
    local body="${RALPHY_AI_COMMENT_DISCLAIMER}

${incomplete_notes}"
    gh issue comment "$issue_num" --repo "$REPO" --body "$body" >/dev/null 2>&1 || \
      log_warn "Failed to comment on issue #$issue_num"
    gh issue edit "$issue_num" --repo "$REPO" \
      --remove-label "$READY_LABEL" --add-label "needs-info" >/dev/null 2>&1 || \
      log_warn "Failed to flip labels on issue #$issue_num"
    return 1
  fi

  if [[ "$result" == *"<promise>COMPLETE</promise>"* ]]; then
    return 2
  fi

  log_warn "AI did not emit an outcome tag for issue #$issue_num"
  return 3
}

# ============================================
# SUB-ISSUE ITERATION
# ============================================

# Dispatches the currently-loaded RALPHY_DISPATCHED_* sub-issue to the AI.
# Echoes "complete" / "incomplete" / "nowork" / "noop" on stdout for the
# epic loop to consume. Side effects: AI runs, commits land on the current
# branch, label flips happen on partial progress.
run_subissue_iteration() {
  retry_count=0

  local issue_num="$RALPHY_DISPATCHED_ISSUE"
  local issue_title="$RALPHY_DISPATCHED_TITLE"
  local current_task="#${issue_num}: ${issue_title}"

  log_info "Active sub-issue: ${BOLD}#${issue_num}${RESET} ${DIM}(${issue_title})${RESET}"

  current_step="Thinking"
  tmpfile=$(mktemp)

  local prompt
  prompt=$(build_subissue_prompt)

  if [[ "$DRY_RUN" == true ]]; then
    log_info "DRY RUN - Would dispatch sub-issue #${issue_num}:"
    echo "${DIM}$prompt${RESET}"
    rm -f "$tmpfile"
    tmpfile=""
    RALPHY_LAST_OUTCOME="noop"
    return 0
  fi

  while [[ $retry_count -lt $MAX_RETRIES ]]; do
    run_ai_command "$prompt" "$tmpfile"

    monitor_progress "$tmpfile" "${current_task:0:40}" &
    monitor_pid=$!

    wait "$ai_pid" 2>/dev/null || true

    kill "$monitor_pid" 2>/dev/null || true
    wait "$monitor_pid" 2>/dev/null || true
    monitor_pid=""

    tput cr 2>/dev/null || printf "\r"
    tput el 2>/dev/null || true

    local result
    result=$(cat "$tmpfile" 2>/dev/null || echo "")

    if [[ -z "$result" ]]; then
      ((retry_count++)) || true
      log_error "Empty response (attempt $retry_count/$MAX_RETRIES)"
      if [[ $retry_count -lt $MAX_RETRIES ]]; then
        log_info "Retrying in ${RETRY_DELAY}s..."
        sleep "$RETRY_DELAY"
        continue
      fi
      rm -f "$tmpfile"
      tmpfile=""
      RALPHY_LAST_OUTCOME="fail"
      return 1
    fi

    local error_msg
    if ! error_msg=$(check_for_errors "$result"); then
      ((retry_count++)) || true
      log_error "API error: $error_msg (attempt $retry_count/$MAX_RETRIES)"
      if [[ $retry_count -lt $MAX_RETRIES ]]; then
        log_info "Retrying in ${RETRY_DELAY}s..."
        sleep "$RETRY_DELAY"
        continue
      fi
      rm -f "$tmpfile"
      tmpfile=""
      RALPHY_LAST_OUTCOME="fail"
      return 1
    fi

    local parsed
    parsed=$(parse_ai_result "$result")
    local response
    response=$(echo "$parsed" | sed '/^---TOKENS---$/,$d')
    local token_data
    token_data=$(echo "$parsed" | sed -n '/^---TOKENS---$/,$p' | tail -3)
    local input_tokens
    input_tokens=$(echo "$token_data" | sed -n '1p')
    local output_tokens
    output_tokens=$(echo "$token_data" | sed -n '2p')
    local actual_cost
    actual_cost=$(echo "$token_data" | sed -n '3p')

    printf "  ${GREEN}✓${RESET} %-16s │ %s\n" "Done" "${current_task:0:40}"

    if [[ -n "$response" ]]; then
      echo ""
      echo "$response"
    fi

    [[ "$input_tokens" =~ ^[0-9]+$ ]] || input_tokens=0
    [[ "$output_tokens" =~ ^[0-9]+$ ]] || output_tokens=0

    total_input_tokens=$((total_input_tokens + input_tokens))
    total_output_tokens=$((total_output_tokens + output_tokens))

    if [[ -n "$actual_cost" ]]; then
      if [[ "$actual_cost" == duration:* ]]; then
        local dur_ms="${actual_cost#duration:}"
        [[ "$dur_ms" =~ ^[0-9]+$ ]] && total_duration_ms=$((total_duration_ms + dur_ms))
      elif [[ "$actual_cost" != "0" ]] && command -v bc &>/dev/null; then
        total_actual_cost=$(echo "scale=6; $total_actual_cost + $actual_cost" | bc 2>/dev/null || echo "$total_actual_cost")
      fi
    fi

    rm -f "$tmpfile"
    tmpfile=""
    if [[ "$AI_ENGINE" == "codex" ]] && [[ -n "$CODEX_LAST_MESSAGE_FILE" ]]; then
      rm -f "$CODEX_LAST_MESSAGE_FILE"
      CODEX_LAST_MESSAGE_FILE=""
    fi

    local outcome_code=0
    handle_subissue_outcome "$result" "$issue_num" || outcome_code=$?
    case $outcome_code in
    0) RALPHY_LAST_OUTCOME="complete" ;;
    1) RALPHY_LAST_OUTCOME="incomplete" ;;
    2) RALPHY_LAST_OUTCOME="nowork" ;;
    *) RALPHY_LAST_OUTCOME="noop" ;;
    esac
    return 0
  done

  RALPHY_LAST_OUTCOME="fail"
  return 1
}

# ============================================
# EPIC LOOP
# ============================================

run_epic_loop() {
  while true; do
    if [[ $MAX_ITERATIONS -gt 0 ]] && [[ $iteration -ge $MAX_ITERATIONS ]]; then
      log_warn "Reached max iterations ($MAX_ITERATIONS)"
      break
    fi

    log_info "Discovering open epics..."
    discover_epics

    if [[ ${#EPIC_LIST[@]} -eq 0 ]]; then
      log_success "No open '${READY_LABEL}' issues remain. Exiting."
      break
    fi

    if ! select_active_epic; then
      log_success "No epic has eligible sub-issues right now. Exiting."
      break
    fi

    local epic="$RALPHY_EPIC"
    local epic_title="$RALPHY_EPIC_TITLE"
    log_info "Active epic: ${BOLD}#${epic}${RESET} ${DIM}(${epic_title})${RESET}"

    local branch
    branch=$(ensure_epic_branch "$epic" "$epic_title") || {
      log_error "Could not prepare epic branch; aborting"
      break
    }

    SUBISSUE_PROCESSED=()
    order_epic_subissues "$epic"

    local completed_subs=()
    local partial=false
    local saw_failure=false

    while pick_next_subissue; do
      ((iteration++)) || true
      SUBISSUE_PROCESSED[$RALPHY_DISPATCHED_ISSUE]=1

      local outcome
      RALPHY_LAST_OUTCOME=""
      run_subissue_iteration || true
      outcome="$RALPHY_LAST_OUTCOME"

      case "$outcome" in
      complete)
        completed_subs+=("$RALPHY_DISPATCHED_ISSUE")
        mark_subissue_in_pr "$RALPHY_DISPATCHED_ISSUE"
        ;;
      incomplete)
        partial=true
        # Sub-issue was demoted to needs-info; it no longer carries
        # ready-for-agent so it won't be re-picked.
        ;;
      nowork)
        # Sub-issue required no work. Treat as completed for PR purposes
        # and strip ready-for-agent so it's not re-picked.
        completed_subs+=("$RALPHY_DISPATCHED_ISSUE")
        mark_subissue_in_pr "$RALPHY_DISPATCHED_ISSUE"
        ;;
      fail)
        log_warn "Sub-issue #${RALPHY_DISPATCHED_ISSUE} failed after $MAX_RETRIES attempts"
        partial=true
        saw_failure=true
        ;;
      *)
        partial=true
        ;;
      esac

      if [[ $MAX_ITERATIONS -gt 0 ]] && [[ $iteration -ge $MAX_ITERATIONS ]]; then
        log_warn "Reached max iterations ($MAX_ITERATIONS)"
        break
      fi
    done

    if [[ ${#completed_subs[@]} -eq 0 ]]; then
      log_warn "Epic #${epic}: no sub-issue completed; not opening a PR"
      if [[ "$saw_failure" == true ]]; then
        # Avoid an infinite loop: stop if every sub-issue failed.
        break
      fi
      # Otherwise the epic stalled (all sub-issues went to needs-info or
      # had errors). Move on to the next epic.
      continue
    fi

    local draft="false"
    [[ "$partial" == true ]] && draft="true"
    open_epic_pr "$epic" "$epic_title" "$branch" completed_subs "$draft" || \
      log_warn "Epic #${epic}: PR creation failed"

    # Move back to base for the next epic to start cleanly.
    git checkout "$BASE" >/dev/null 2>&1 || true

    if [[ -n "$EPIC_FILTER" ]]; then
      log_info "--epic was set; stopping after this epic"
      break
    fi
  done
}

# ============================================
# SUMMARY
# ============================================

show_summary() {
  echo ""
  echo "${BOLD}============================================${RESET}"
  echo "${GREEN}Ralphy run complete.${RESET} Iterations: $iteration."
  echo "${BOLD}============================================${RESET}"
  echo ""
  echo "${BOLD}>>> Cost Summary${RESET}"

  if [[ "$AI_ENGINE" == "cursor" ]] || [[ "$AI_ENGINE" == "droid" ]] || [[ "$AI_ENGINE" == "copilot" ]]; then
    echo "${DIM}Token usage not available (CLI doesn't expose this data)${RESET}"
    if [[ "$total_duration_ms" -gt 0 ]]; then
      local dur_sec=$((total_duration_ms / 1000))
      local dur_min=$((dur_sec / 60))
      local dur_sec_rem=$((dur_sec % 60))
      if [[ "$dur_min" -gt 0 ]]; then
        echo "Total API time: ${dur_min}m ${dur_sec_rem}s"
      else
        echo "Total API time: ${dur_sec}s"
      fi
    fi
  else
    echo "Input tokens:  $total_input_tokens"
    echo "Output tokens: $total_output_tokens"
    echo "Total tokens:  $((total_input_tokens + total_output_tokens))"

    if [[ "$AI_ENGINE" == "opencode" ]] && command -v bc &>/dev/null; then
      local has_actual_cost
      has_actual_cost=$(echo "$total_actual_cost > 0" | bc 2>/dev/null || echo "0")
      if [[ "$has_actual_cost" == "1" ]]; then
        echo "Actual cost:   \$${total_actual_cost}"
      else
        local cost
        cost=$(calculate_cost "$total_input_tokens" "$total_output_tokens")
        echo "Est. cost:     \$$cost"
      fi
    else
      local cost
      cost=$(calculate_cost "$total_input_tokens" "$total_output_tokens")
      echo "Est. cost:     \$$cost"
    fi
  fi

  echo "${BOLD}============================================${RESET}"
}

# ============================================
# MAIN
# ============================================

main() {
  parse_args "$@"

  if [[ "$BROWSER_ENABLED" == "auto" ]] && [[ -f "$CONFIG_FILE" ]]; then
    BROWSER_ENABLED=$(load_browser_setting)
  fi

  if [[ "$INIT_MODE" == true ]]; then
    init_ralphy_config
    exit 0
  fi
  if [[ "$SHOW_CONFIG" == true ]]; then
    show_ralphy_config
    exit 0
  fi
  if [[ -n "$ADD_RULE" ]]; then
    add_ralphy_rule "$ADD_RULE"
    exit 0
  fi

  if [[ "$DRY_RUN" == true ]] && [[ "$MAX_ITERATIONS" -eq 0 ]]; then
    MAX_ITERATIONS=1
  fi

  trap cleanup EXIT
  trap 'exit 130' INT TERM HUP

  check_requirements

  echo "${BOLD}============================================${RESET}"
  echo "${BOLD}Ralphy${RESET} - Epic-driven loop over GitHub Issues"
  local engine_display
  case "$AI_ENGINE" in
  opencode) engine_display="${CYAN}OpenCode${RESET}" ;;
  cursor)   engine_display="${YELLOW}Cursor Agent${RESET}" ;;
  codex)    engine_display="${BLUE}Codex${RESET}" ;;
  qwen)     engine_display="${GREEN}Qwen-Code${RESET}" ;;
  droid)    engine_display="${MAGENTA}Factory Droid${RESET}" ;;
  copilot)  engine_display="${BLUE}GitHub Copilot${RESET}" ;;
  *)        engine_display="${MAGENTA}Claude Code${RESET}" ;;
  esac
  echo "Engine:  $engine_display"
  echo "Repo:    ${CYAN}$REPO${RESET}"
  echo "Base:    ${CYAN}$BASE${RESET}"
  [[ -n "$EPIC_FILTER" ]] && echo "Epic:    ${CYAN}#$EPIC_FILTER${RESET}"
  if [[ -d "$RALPHY_DIR" ]]; then
    echo "Config:  ${GREEN}$RALPHY_DIR/${RESET} (rules loaded)"
  fi

  local mode_parts=()
  [[ "$DRY_RUN" == true ]] && mode_parts+=("dry-run")
  [[ $MAX_ITERATIONS -gt 0 ]] && mode_parts+=("max:$MAX_ITERATIONS")
  if [[ ${#mode_parts[@]} -gt 0 ]]; then
    echo "Mode:    ${YELLOW}${mode_parts[*]}${RESET}"
  fi
  echo "${BOLD}============================================${RESET}"

  run_epic_loop
  show_summary
  notify_done
}

main "$@"
